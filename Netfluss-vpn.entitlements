<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for URLSession (external IP lookup) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Personal VPN (NEVPNManager) — lets NetFluss create/start IKEv2 VPNs.
         RESTRICTED: requires a provisioning profile that grants it (see
         Packaging/VPN/README.md). Signing with this entitlement but no matching
         provisioning profile makes the app fail to launch — only use this
         entitlements file for the IKEv2-enabled build. -->
    <key>com.apple.developer.networking.vpn.api</key>
    <array>
        <string>allow-vpn</string>
    </array>
    <!-- application-identifier gives the app a data-protection-keychain access
         group, which NEVPNManager needs to resolve the password reference.
         Authorized by the embedded provisioning profile. -->
    <key>com.apple.application-identifier</key>
    <string>D6P24X5377.com.local.netfluss</string>
    <key>com.apple.developer.team-identifier</key>
    <string>D6P24X5377</string>
</dict>
</plist>
